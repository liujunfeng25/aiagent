# =============================================================================
# 环境变量模板（可安全提交到 Git）
#
# 新电脑 clone 后在本目录执行：
#   cp .env.example .env
# 然后编辑 .env，把下面占位符换成与你旧电脑 / 服务器一致的值。
# 旧电脑上的 .env 通常没有被 git 跟踪，可用 U 盘、加密通道或密码管理器拷过来。
#
# 数据洞察健康检查：GET http://localhost:8000/api/insights/business/health
# =============================================================================

# ---------- 数据洞察 / 驾驶舱（订单、单品、区域等，直连只读业务 MySQL）----------
# 必须至少配置 HOST，否则会 503「未配置业务库连接」
# 若不配环境变量，也可在网页「数据源」里添加第一条 MySQL 作为兜底（但 HOST 仍建议写明便于排查）
INSIGHTS_MYSQL_HOST=
INSIGHTS_MYSQL_PORT=3306
INSIGHTS_MYSQL_USER=
INSIGHTS_MYSQL_PASSWORD=
INSIGHTS_MYSQL_DATABASE=

# 可选：订单明细表映射（见 app/business_insights/data_catalog.md）
# INSIGHTS_ORDER_ITEMS_TABLE=
# INSIGHTS_ORDER_ITEMS_FK=
# INSIGHTS_ORDERS_PK=
# INSIGHTS_ORDER_ITEMS_NAME_COL=
# INSIGHTS_ORDER_ITEMS_PRICE_COL=
# INSIGHTS_ORDER_ITEMS_QTY_COLS=

# ---------- SXW 业务数据库（智能物流等模块）----------
SXW_MYSQL_HOST=
SXW_MYSQL_PORT=3306
SXW_MYSQL_USER=
SXW_MYSQL_PASSWORD=
SXW_MYSQL_DATABASE=
SXW_MYSQL_SUPP_CODE=

# ---------- 高德地图 JS API（物联驾驶舱地图等）----------
AMAP_JSAPI_KEY=
AMAP_SECURITY_JSCODE=

# ---------- 北斗 GPS18 ----------
GPS18_OPENAPI_BASE=http://openapi.18gps.net
GPS18_LOGIN_NAME=
GPS18_LOGIN_PASSWORD=
GPS18_MDS=
GPS18_UNIT_ID=
GPS18_HISTORY_MAP_TYPE=BAIDU
GPS18_HISTORY_DEBUG=1

# ---------- 乐橙(IMOU) 摄像头 ----------
IMOU_APP_ID=
IMOU_APP_SECRET=
IMOU_OPENAPI_BASE=https://openapi.lechange.cn/openapi

# ---------- 萤石(YS7) 摄像头 ----------
YS7_APP_KEY=
YS7_APP_SECRET=
YS7_OPENAPI_BASE=https://open.ys7.com/api/lapp

# ---------- 票据识别：百度表格 OCR（可选；不填可走 mock / 其它兜底）----------
# DOCUMENTS_BAIDU_TABLE_API_KEY=
# DOCUMENTS_OCR_ENGINE=baidu
